# ─── Required ─────────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens. Use a long, random string (32+ characters).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Supabase, Railway, Render, etc.)
# Leave unset to use SQLite for local development.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# localhost origins are always allowed automatically.
# Example: https://inukawijerathna.me,https://www.inukawijerathna.me
ALLOWED_ORIGINS=https://inukawijerathna.me

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Place these in frontend/.env.local (never commit .env.local)

# Backend API base URL consumed by the React app
# VITE_API_URL=http://localhost:5000/api
